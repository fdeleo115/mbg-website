---
layout: base.njk
pageTitle: Resources
activePage: resources
permalink: /resources/
---

<section class="page-header">
  <div class="container">
    <h1>Resources</h1>
    <p>Moot problems, competitor and judge packages, and advocacy guides shared across member societies.</p>
  </div>
</section>

<section>
  <div class="container">
    <div class="resource-ledger">
      {%- for res in collections.resources %}
      {% set link = res.data.file or res.data.url %}
      <div class="resource-entry">
        <div class="resource-main">
          {% if res.data.category %}<span class="resource-cat">{{ res.data.category }}</span>{% endif %}
          <h3>{{ res.data.title }}</h3>
          {% if res.data.description %}<p>{{ res.data.description }}</p>{% endif %}
        </div>
        {% if link %}
        <a href="{{ link }}" class="btn btn-primary resource-action"{% if res.data.url %} target="_blank" rel="noopener"{% endif %}>{% if res.data.url %}Open{% else %}Download{% endif %}</a>
        {% endif %}
      </div>
      {%- endfor %}
      {%- if collections.resources.length == 0 %}
      <p class="empty-state">Resources will be published here. Member societies can submit materials through the <a href="/contact/">contact page</a>.</p>
      {%- endif %}
    </div>
  </div>
</section>
