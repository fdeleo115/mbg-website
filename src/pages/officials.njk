---
layout: base.njk
pageTitle: Elected Officials
activePage: officials
permalink: /officials/
---

<section class="page-header">
  <div class="container">
    <h1>Elected Officials</h1>
    <p>The elected executive who organize and run the Moot Board of Governors day to day — distinct from the representatives who sit on the Board.</p>
  </div>
</section>

{% set currentOfficials = collections.officials | where("status", "current") %}
{% set alumniOfficials = collections.officials | where("status", "alumni") %}

<section class="bg-cream">
  <div class="container">
    <div class="section-header">
      <span class="eyebrow">In Office</span>
      <h2>Current Officials</h2>
      <div class="line"></div>
    </div>
    <div class="exec-grid">
      {%- for m in currentOfficials %}
      <div class="exec-card">
        <div class="exec-avatar">
          {% if m.data.photo %}
          <img src="{{ m.data.photo }}" alt="{{ m.data.name }}" style="object-fit: {{ m.data.photoSize or 'cover' }}; object-position: {{ m.data.photoPosition or 'center' }};{% if m.data.photoZoom and m.data.photoZoom != 1 %} transform: scale({{ m.data.photoZoom }}); transform-origin: {{ m.data.photoPosition or 'center' }};{% endif %}">
          {% else %}
          <div class="avatar">{{ m.data.name[0] }}</div>
          {% endif %}
        </div>
        <h4>{{ m.data.name }}</h4>
        <div class="role">{{ m.data.role }}</div>
        {% if m.data.society %}<div class="society-school">{{ m.data.society }}</div>{% endif %}
      </div>
      {%- endfor %}
      {%- if currentOfficials.length == 0 %}
      <p class="empty-state">Elected officials will appear here.</p>
      {%- endif %}
    </div>
  </div>
</section>

{% if alumniOfficials.length %}
<section>
  <div class="container">
    <div class="section-header">
      <span class="eyebrow">Past Service</span>
      <h2>Alumni Officials</h2>
      <div class="line"></div>
    </div>
    <div class="exec-grid exec-grid--alumni">
      {%- for m in alumniOfficials %}
      <div class="exec-card exec-card--alumni">
        <div class="exec-avatar">
          {% if m.data.photo %}
          <img src="{{ m.data.photo }}" alt="{{ m.data.name }}" style="object-fit: {{ m.data.photoSize or 'cover' }}; object-position: {{ m.data.photoPosition or 'center' }};{% if m.data.photoZoom and m.data.photoZoom != 1 %} transform: scale({{ m.data.photoZoom }}); transform-origin: {{ m.data.photoPosition or 'center' }};{% endif %}">
          {% else %}
          <div class="avatar">{{ m.data.name[0] }}</div>
          {% endif %}
        </div>
        <h4>{{ m.data.name }}</h4>
        <div class="role">{{ m.data.role }}</div>
        {% if m.data.term %}<div class="exec-term">{{ m.data.term }}</div>{% endif %}
      </div>
      {%- endfor %}
    </div>
  </div>
</section>
{% endif %}
