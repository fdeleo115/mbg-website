---
layout: base.njk
pageTitle: About
activePage: about
permalink: /about/
---

<section class="page-header">
  <div class="container">
    <h1>About the Board</h1>
    <p>Learn about the Moot Board of Governors and our mandate.</p>
  </div>
</section>

<section>
  <div class="container">
    <div class="content-block">
      <h2>Our Mandate</h2>
      <p>{{ about.mission }}</p>
    </div>
    <div class="principles">
      <div class="principle">
        <div class="principle-num">I</div>
        <div class="principle-body">
          <h3>National Competitions</h3>
          <p>{{ about.advocacy }}</p>
        </div>
      </div>
      <div class="principle">
        <div class="principle-num">II</div>
        <div class="principle-body">
          <h3>National Network</h3>
          <p>{{ about.community }}</p>
        </div>
      </div>
      <div class="principle">
        <div class="principle-num">III</div>
        <div class="principle-body">
          <h3>Shared Resources</h3>
          <p>{{ about.education }}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section>
  <div class="container">
    <div class="section-header">
      <h2>Frequently Asked Questions</h2>
      <div class="line"></div>
    </div>
    <div class="faq-list">
      {%- for item in about.faq %}
      <div class="faq-item">
        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">{{ item.question }}</button>
        <div class="faq-answer"><p>{{ item.answer }}</p></div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>
