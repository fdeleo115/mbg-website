---
layout: base.njk
pageTitle: Contact
activePage: contact
permalink: /contact/
---

<section class="page-header">
  <div class="container">
    <h1>Contact the Board</h1>
    <p>Want your society to join, compete in a national moot, or partner with us? Reach out.</p>
  </div>
</section>

<section>
  <div class="container">
    <div class="contact-grid">
      <div class="contact-info">
        <h3>Get in Touch</h3>
        <p>Whether you represent a pre-law society interested in joining the Board, a student looking to compete, or a partner, send us a message and a representative will get back to you.</p>
        <div class="contact-channels">
          {% if site.email %}
          <a class="contact-channel" href="mailto:{{ site.email }}">
            <span class="cc-label">Email</span>
            <span class="cc-value">{{ site.email }}</span>
          </a>
          {% endif %}
          <a class="contact-channel" href="{{ site.instagram }}" target="_blank" rel="noopener">
            <span class="cc-label">Instagram</span>
            <span class="cc-value">Follow the Board &rarr;</span>
          </a>
          <a class="contact-channel" href="{{ site.linkedin }}" target="_blank" rel="noopener">
            <span class="cc-label">LinkedIn</span>
            <span class="cc-value">Connect with us &rarr;</span>
          </a>
        </div>
      </div>
      <form class="contact-form" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field">
        <input type="hidden" name="form-name" value="contact">
        <p class="hidden" style="display:none"><label>Don't fill this out: <input name="bot-field"></label></p>
        <input type="text" name="name" placeholder="Your Name" required minlength="2" maxlength="100" autocomplete="name">
        <input type="email" name="email" placeholder="Your Email" required maxlength="254" autocomplete="email">
        <input type="text" name="society" placeholder="Your Society / University (if applicable)" maxlength="150">
        <select name="subject" required>
          <option value="" disabled selected>What is this about?</option>
          <option>Joining the Board</option>
          <option>National Competition — Competitor</option>
          <option>National Competition — Judge</option>
          <option>Partnership / Sponsorship</option>
          <option>General Question</option>
        </select>
        <textarea name="message" placeholder="Your Message" required minlength="10" maxlength="2000"></textarea>
        <button type="submit" class="btn btn-primary">Send Message</button>
      </form>
    </div>
  </div>
</section>
