---
layout: base.njk
pageTitle: Events
activePage: events
permalink: /events/
---

<section class="page-header">
  <div class="container">
    <h1>Events</h1>
    <p>National events, info sessions, and key deadlines across the Board's member societies.</p>
  </div>
</section>

<section>
  <div class="container">
    <div class="section-header">
      <h2>Upcoming Events</h2>
      <div class="line"></div>
    </div>
    <div class="schedule-list">
      {%- for event in collections.events %}
      <div class="schedule-item {% if event.data.photo %}schedule-item--has-photo{% endif %}">
        {% if event.data.photo %}
        <div class="schedule-photo">
          <img src="{{ event.data.photo }}" alt="{{ event.data.title }}" style="object-fit: {{ event.data.photoSize or 'cover' }}; object-position: {{ event.data.photoPosition or 'center' }};">
        </div>
        {% endif %}
        <div class="schedule-date">
          <div class="month">{{ event.data.date | monthShort }}</div>
          <div class="day">{{ event.data.date | dayNum }}</div>
        </div>
        <div class="schedule-info">
          <h4>{{ event.data.title }}</h4>
          <p>{{ event.data.description }}</p>
          {% if event.data.time %}<div class="time">{{ event.data.time }}</div>{% endif %}
          {% if event.data.location %}<div class="location">{{ event.data.location }}</div>{% endif %}
        </div>
      </div>
      {%- endfor %}
      {%- if collections.events.length == 0 %}
      <p class="empty-state">No upcoming events scheduled. Follow us on <a href="{{ site.instagram }}">Instagram</a> for announcements.</p>
      {%- endif %}
    </div>
  </div>
</section>
