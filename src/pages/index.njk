---
layout: base.njk
pageTitle: Home
activePage: home
permalink: /
---

<section class="reg-hero">
  <div class="container">
    <div class="reg-hero-inner">
      <div class="reg-hero-seal">
        <img src="/assets/logo.jpg" alt="{{ site.shortTitle }} crest">
      </div>
      <div class="reg-hero-text">
        <span class="eyebrow">National Association &middot; Canada</span>
        <h1>Moot Board of <em>Governors</em></h1>
        <p>{{ site.description }}</p>
        <div class="reg-hero-actions">
          <a href="/societies/" class="btn btn-primary">Member Societies</a>
          <a href="/contact/" class="btn btn-outline">Join the Board</a>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="reg-index">
  <div class="container">
    <div class="reg-index-head">
      <div>
        <span class="eyebrow">The Register</span>
        <h2>Navigate the Board</h2>
      </div>
      <p>Everything the Board maintains — societies, governance, competitions and resources — indexed below.</p>
    </div>

    <div class="reg-list">
      {% set sections = [
        { num: "01", url: "/about/", title: "About", desc: "Our mandate, mission & frequently asked questions" },
        { num: "02", url: "/societies/", title: "Member Societies", desc: "Pre-law & mooting societies across Canada" },
        { num: "03", url: "/members/", title: "Pre-Law Members", desc: "Individual members recognized by the Board" },
        { num: "04", url: "/board/", title: "The Board", desc: "The society representatives who govern the association" },
        { num: "05", url: "/officials/", title: "Elected Officials", desc: "The exec who organize & run the Board" },
        { num: "06", url: "/competitions/", title: "Competitions", desc: "National moot competitions & results" },
        { num: "07", url: "/gala/", title: "Championship & Gala", desc: "The Board's flagship weekend & annual awards" },
        { num: "08", url: "/news/", title: "News & Events", desc: "Announcements, upcoming events & deadlines" },
        { num: "09", url: "/resources/", title: "Resources", desc: "Moot problems, packages & advocacy guides" },
        { num: "10", url: "/contact/", title: "Contact", desc: "Join, compete, or partner with the Board" }
      ] %}
      {%- for s in sections %}
      <a href="{{ s.url }}" class="reg-row">
        <div class="reg-num">{{ s.num }}</div>
        <div class="reg-row-main">
          <h3>{{ s.title }}</h3>
          <p>{{ s.desc }}</p>
        </div>
        <span class="reg-arrow">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </span>
      </a>
      {%- endfor %}
    </div>
  </div>
</section>
